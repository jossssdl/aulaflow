{
  "name": "aulaflow",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @aulas/web run dev",
    "dev:solver": "cd apps/solver-api && py -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "build": "npm --workspace @aulas/web run build",
    "lint": "npm --workspace @aulas/web run lint",
    "typecheck": "npm --workspace @aulas/web run typecheck",
    "test:solver": "cd apps/solver-api && py -m pytest"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0",
    "python": ">=3.11"
  }
}
